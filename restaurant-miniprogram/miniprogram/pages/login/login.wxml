<navigation-bar title="登录" back="{{false}}" color="black" background="#ffffff"></navigation-bar>
<view class="login-page">
  <view class="login-panel">
    <view class="brand">
      <text class="title">欢迎光临</text>
      <text class="subtitle">扫码点餐 · 自助下单</text>
    </view>

    <view class="form">
      <view class="field">
        <text class="label">手机号</text>
        <input
          class="input"
          type="number"
          maxlength="11"
          value="{{phone}}"
          placeholder="请输入手机号"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="field">
        <text class="label">密码</text>
        <input
          class="input"
          password
          value="{{password}}"
          placeholder="请输入密码"
          bindinput="onPasswordInput"
        />
      </view>

      <button class="submit" loading="{{loading}}" disabled="{{loading}}" bindtap="onSubmit">
        {{loading ? '登录中...' : '登录'}}
      </button>

      <button class="wechat-submit" loading="{{wxLoading}}" disabled="{{wxLoading || loading}}" bindtap="onWxLogin">
        {{wxLoading ? '微信登录中...' : '微信一键登录'}}
      </button>

      <text wx:if="{{error}}" class="error">{{error}}</text>
    </view>
  </view>
</view>
