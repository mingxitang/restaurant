<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.restaurant.mapper.CategoryMapper">
    <select id="findAll" resultType="Category">
        SELECT * FROM category ORDER BY category_id DESC
    </select>

    <select id="findPage" resultType="Category">
        SELECT * FROM category ORDER BY category_id DESC LIMIT #{offset}, #{size}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM category
    </select>

    <select id="findById" resultType="Category">
        SELECT * FROM category WHERE category_id = #{categoryId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="categoryId">
        INSERT INTO category(category_name) VALUES(#{categoryName})
    </insert>

    <update id="update">
        UPDATE category SET category_name = #{categoryName} WHERE category_id = #{categoryId}
    </update>

    <delete id="delete">
        DELETE FROM category WHERE category_id = #{categoryId}
    </delete>
</mapper>
